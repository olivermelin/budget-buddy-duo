# Supabase – hämta dessa från: https://supabase.com/dashboard/project/<ditt-projekt>/settings/api
VITE_SUPABASE_URL=https://<din-projekt-id>.supabase.co
VITE_SUPABASE_ANON_KEY=<din-anon-nyckel>

# Sentry – hämta DSN från: https://sentry.io → Project Settings → Client Keys
# Lämna tom i lokal dev om du inte vill skicka fel till Sentry
VITE_SENTRY_DSN=
